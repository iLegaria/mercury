# Database
DB_USERNAME=ke_user
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432

# RabbitMQ
RABBITMQ_USERNAME=ke_user
RABBITMQ_PASSWORD=your_rabbitmq_password_here
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Cohere API
COHERE_API_KEY=your_cohere_api_key_here

# Storage (solo necesario en Docker; local usa ~/knowledge-engine/uploads por defecto)
# STORAGE_UPLOAD_DIR=/app/uploads

# WhatsApp via Green API (https://green-api.com)
# 1. Crea cuenta en green-api.com → crea instancia → escanea QR con tu WhatsApp
# 2. En el panel de la instancia configura el Webhook URL: https://<tu-dominio>/webhook/whatsapp
# 3. Activa "Incoming webhooks" en la configuración de la instancia
WHATSAPP_ENABLED=false
GREENAPI_INSTANCE_ID=your_instance_id_here
GREENAPI_TOKEN=your_token_here
# GREENAPI_BASE_URL=https://api.green-api.com
# GREENAPI_WEBHOOK_TOKEN=optional_secret_to_verify_incoming_webhooks
# WHATSAPP_USER_CHAT_ID=521234567890@c.us   # tu número en formato Green API
# WHATSAPP_USER_ID=your_user_uuid_here
# WHATSAPP_REMINDER_CRON=0 0 8 * * *
# WHATSAPP_MAX_CARDS=10
# Deck selection is managed from the UI (toggle per deck in Flashcards page)
